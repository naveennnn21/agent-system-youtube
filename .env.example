# =============================================================================
# YouTube Shorts AI Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running the app.
#   cp .env.example .env
# =============================================================================

# --- Application --------------------------------------------------------------
APP_NAME=youtube_shorts_agent
APP_ENV=development
DEBUG=true

# --- API Server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# --- PostgreSQL Database ------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/youtube_shorts_agent
DATABASE_SYNC_URL=postgresql://postgres:postgres@db:5432/youtube_shorts_agent

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# --- SQLAlchemy connection pool (staging/production) -------------------------
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# --- YouTube Data API ---------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=DEBUG

# --- Celery Task Queue --------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# --- CORS ---------------------------------------------------------------------
CORS_ORIGINS=["*"]
