# =============================================================================
# YouTube Shorts AI Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running the app.
#   cp .env.example .env
# =============================================================================

# --- Application --------------------------------------------------------------
APP_NAME=youtube_shorts_agent
APP_ENV=development
DEBUG=true

# --- API Server ---------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- PostgreSQL Database ------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/youtube_shorts_agent
DATABASE_SYNC_URL=postgresql://postgres:postgres@db:5432/youtube_shorts_agent

# --- Redis --------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# --- SQLAlchemy connection pool (staging/production) -------------------------
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- OpenAI -------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key-here

# --- Anthropic Claude ---------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-5-20250929
CLAUDE_MAX_TOKENS=1200
CLAUDE_HTTP_TIMEOUT=30
SCRIPT_TARGET_SECONDS=45

# --- YouTube SEO Generation ---------------------------------------------------
SEO_TITLE_MAX_LENGTH=100
SEO_DESCRIPTION_MAX_LENGTH=5000
SEO_MAX_HASHTAGS=8
SEO_MAX_KEYWORDS=20
SEO_MIN_OVERALL_SCORE=60

# --- YouTube Upload -----------------------------------------------------------
YOUTUBE_OAUTH_CLIENT_ID=your-youtube-oauth-client-id
YOUTUBE_OAUTH_CLIENT_SECRET=your-youtube-oauth-client-secret
YOUTUBE_OAUTH_REFRESH_TOKEN=your-youtube-oauth-refresh-token
YOUTUBE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
YOUTUBE_UPLOAD_SCOPE=https://www.googleapis.com/auth/youtube.upload
YOUTUBE_API_BASE_URL=https://www.googleapis.com
YOUTUBE_UPLOAD_BASE_URL=https://www.googleapis.com/upload/youtube/v3
YOUTUBE_WATCH_URL_TEMPLATE=https://www.youtube.com/watch?v={video_id}
YOUTUBE_UPLOAD_TIMEOUT=120
YOUTUBE_DEFAULT_CATEGORY_ID=22
YOUTUBE_DEFAULT_PRIVACY_STATUS=private
YOUTUBE_NOTIFY_SUBSCRIBERS=false
YOUTUBE_SELF_DECLARED_MADE_FOR_KIDS=false
YOUTUBE_CONTAINS_SYNTHETIC_MEDIA=true

# --- Learning Agent -----------------------------------------------------------
LEARNING_LOOKBACK_DAYS=90
LEARNING_TOP_N=5
LEARNING_MAX_SAMPLES=500
LEARNING_MIN_VIEWS=100
LEARNING_MODEL_VERSION=learning-agent-v1

# --- Analytics Agent ----------------------------------------------------------
YOUTUBE_ANALYTICS_BASE_URL=https://youtubeanalytics.googleapis.com/v2
YOUTUBE_ANALYTICS_SCOPE=https://www.googleapis.com/auth/yt-analytics.readonly
YOUTUBE_ANALYTICS_IDS=channel==MINE
YOUTUBE_ANALYTICS_METRICS=["views","estimatedMinutesWatched","averageViewDuration","averageViewPercentage","subscribersGained","likes","comments","shares","annotationClickThroughRate"]
YOUTUBE_ANALYTICS_LOOKBACK_DAYS=7
YOUTUBE_ANALYTICS_COLLECTION_LIMIT=100
YOUTUBE_ANALYTICS_HTTP_TIMEOUT=60

# --- LangGraph Workflow -------------------------------------------------------
WORKFLOW_RETRY_ATTEMPTS=3
WORKFLOW_RETRY_BASE_DELAY=0.5
WORKFLOW_RETRY_MAX_DELAY=5

# --- Voice Generation ---------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
AUDIO_STORAGE_PATH=storage/audio
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_STABILITY=0.45
ELEVENLABS_SIMILARITY_BOOST=0.8
OPENAI_BASE_URL=https://api.openai.com
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_INSTRUCTIONS=
VOICE_REGISTRY_JSON=
VOICE_HTTP_TIMEOUT=30
VOICE_RETRY_ATTEMPTS=3
VOICE_RETRY_BASE_DELAY=0.5
VOICE_RETRY_MAX_DELAY=4.0

# --- Visual Generation --------------------------------------------------------
VISUAL_STORAGE_PATH=storage/visuals
FLUX_API_KEY=your-flux-api-key-here
FLUX_BASE_URL=https://api.bfl.ai
FLUX_GENERATE_ENDPOINT=/v1/flux-pro-1.1
FLUX_RESULT_ENDPOINT=/v1/get_result
FLUX_AUTH_HEADER=x-key
FLUX_MODEL=flux-pro-1.1
FLUX_POLL_INTERVAL=1
FLUX_POLL_ATTEMPTS=30
STABILITY_API_KEY=your-stability-api-key-here
STABILITY_BASE_URL=https://api.stability.ai
STABILITY_GENERATE_ENDPOINT=/v2beta/stable-image/generate/core
STABILITY_MODEL=stable-image-core
VISUAL_HTTP_TIMEOUT=60
VISUAL_RETRY_ATTEMPTS=3
VISUAL_RETRY_BASE_DELAY=0.5
VISUAL_RETRY_MAX_DELAY=4.0
VISUAL_WIDTH=1024
VISUAL_HEIGHT=1792
VISUAL_MAX_SCENES=6
VISUAL_STYLE=cinematic, vertical YouTube Short, high detail

# --- Video Editing ------------------------------------------------------------
VIDEO_STORAGE_PATH=storage/videos
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_CRF=18
VIDEO_PRESET=veryfast
VIDEO_AUDIO_BITRATE=192k
VIDEO_MAX_DURATION_SECONDS=60
VIDEO_MIN_DURATION_SECONDS=30
VIDEO_SUBTITLE_FONT=Arial
VIDEO_SUBTITLE_FONT_SIZE=64
VIDEO_SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
VIDEO_SUBTITLE_OUTLINE_COLOR=&H00000000
VIDEO_SUBTITLE_BACK_COLOR=&H80000000

# --- YouTube Data API ---------------------------------------------------------
YOUTUBE_API_KEY=your-youtube-api-key-here

# --- Logging ------------------------------------------------------------------
LOG_LEVEL=DEBUG

# --- Celery Task Queue --------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_TASK_TRACK_STARTED=true
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_WORKER_CONCURRENCY=2
CELERY_TASK_MAX_RETRIES=3
CELERY_TASK_RETRY_BACKOFF=60
CELERY_TASK_RETRY_BACKOFF_MAX=600
CELERY_TASK_SOFT_TIME_LIMIT=6900
CELERY_TASK_TIME_LIMIT=7200

# --- Automation ---------------------------------------------------------------
AUTOMATION_DAILY_SHORTS_COUNT=3
AUTOMATION_DAILY_CRON_HOUR=9
AUTOMATION_DAILY_CRON_MINUTE=0
AUTOMATION_SHORT_SPACING_MINUTES=20
AUTOMATION_DEFAULT_CATEGORY=technology
AUTOMATION_AUTOSTART_QUEUE=automation
AUTOMATION_SHORTS_QUEUE=shorts
AUTOMATION_ANALYTICS_QUEUE=analytics
AUTOMATION_NOTIFICATIONS_QUEUE=notifications
AUTOMATION_QUEUE_NAMES=["automation","shorts","analytics","notifications"]
NOTIFICATIONS_ENABLED=true
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_WEBHOOK_TIMEOUT=10

# --- CORS ---------------------------------------------------------------------
CORS_ORIGINS=["*"]
