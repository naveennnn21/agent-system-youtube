{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "celery -A app.automation.celery_app:celery_app worker --loglevel=INFO --queues=automation,shorts,analytics,notifications --concurrency=${CELERY_WORKER_CONCURRENCY:-2}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
